{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/dashboard.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/dashboard\\.html", "dest": "/public/dashboard.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
